#!/bin/bash
set -euo pipefail

LOG() { echo "[memguard-system-tune] $*"; }
WARN() { echo "[memguard-system-tune] WARN: $*" >&2; }

if [[ $EUID -ne 0 ]]; then
    echo "memguard-system-tune must be run as root" >&2
    exit 1
fi

# 1. I/O scheduler -> bfq
for sched in /sys/block/*/queue/scheduler; do
    if [[ -f "$sched" ]]; then
        dev=$(basename "$(dirname "$sched")")
        if grep -q 'bfq' "$sched"; then
            if echo bfq > "$sched" 2>/dev/null; then
                LOG "set $dev scheduler to bfq"
            else
                WARN "failed to set $dev scheduler to bfq"
            fi
        else
            LOG "$dev does not support bfq; skipping"
        fi
    fi
done

# 2. ananicy-cpp
if command -v dnf >/dev/null 2>&1; then
    if ! rpm -q ananicy-cpp >/dev/null 2>&1; then
        if dnf install -y ananicy-cpp; then
            LOG "installed ananicy-cpp"
        else
            WARN "failed to install ananicy-cpp"
        fi
    else
        LOG "ananicy-cpp already installed"
    fi
    if systemctl enable --now ananicy-cpp.service; then
        LOG "enabled ananicy-cpp.service"
    else
        WARN "failed to enable ananicy-cpp.service"
    fi
else
    WARN "dnf not available; skipping ananicy-cpp"
fi

# 3. zram via systemd-zram-generator
if command -v systemctl >/dev/null 2>&1; then
    ZRAM_CONF=/etc/systemd/zram-generator.conf
    if [[ -f "$ZRAM_CONF" ]]; then
        LOG "$ZRAM_CONF already exists; skipping zram setup"
    else
        mkdir -p /etc/systemd
        cat > "$ZRAM_CONF" <<'EOF'
[zram0]
zram-size = ram / 2
compression-algorithm = zstd
EOF
        LOG "created $ZRAM_CONF"
        systemctl daemon-reload || true
        if systemctl start systemd-zram-setup@zram0.service 2>/dev/null || \
           systemctl restart systemd-zram-setup@zram0.service 2>/dev/null; then
            LOG "started zram0"
        else
            WARN "failed to start zram0"
        fi
    fi
else
    WARN "systemctl not available; skipping zram setup"
fi

# 4. fstrim
if command -v fstrim >/dev/null 2>&1; then
    if fstrim -a >/dev/null 2>&1; then
        LOG "fstrim completed"
    else
        WARN "fstrim failed"
    fi
else
    WARN "fstrim not available"
fi

# 5. fstab noatime
if [[ -f /etc/fstab ]]; then
    new_fstab=/etc/fstab.memguard-new
    awk '
        /^#/ || /^$/ { print; next }
        {
            fs=$3
            opts=$4
            if ((fs=="ext4" || fs=="xfs" || fs=="btrfs") && \
                opts !~ /(^|,)atime(=|$|,)/ && \
                opts !~ /(^|,)noatime($|,)/ && \
                opts !~ /(^|,)relatime($|,)/) {
                if (opts == "") $4 = "noatime"
                else $4 = opts ",noatime"
            }
            print
        }
    ' /etc/fstab > "$new_fstab"

    if cmp -s /etc/fstab "$new_fstab"; then
        LOG "/etc/fstab already has noatime where needed; no changes"
        rm -f "$new_fstab"
    else
        if command -v findmnt >/dev/null 2>&1; then
            if findmnt --verify "$new_fstab"; then
                backup=/etc/fstab.memguard-backup-$(date +%Y%m%d%H%M%S)
                cp /etc/fstab "$backup"
                LOG "backed up /etc/fstab to $backup"
                mv "$new_fstab" /etc/fstab
                LOG "updated /etc/fstab with noatime where needed"
            else
                WARN "fstab verification failed; not replacing /etc/fstab"
                rm -f "$new_fstab"
            fi
        else
            WARN "findmnt not available; skipping fstab verification"
            backup=/etc/fstab.memguard-backup-$(date +%Y%m%d%H%M%S)
            cp /etc/fstab "$backup"
            LOG "backed up /etc/fstab to $backup"
            mv "$new_fstab" /etc/fstab
            LOG "updated /etc/fstab with noatime where needed"
        fi
    fi
else
    WARN "/etc/fstab not found"
fi

LOG "system tuning complete"
