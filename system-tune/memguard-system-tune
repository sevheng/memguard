#!/bin/bash
set -euo pipefail

LOG() { echo "[memguard-system-tune]" "$*"; }
WARN() { echo "[memguard-system-tune] WARN:" "$*" >&2; }

total_ram_kb() {
    awk '/MemTotal:/ {print $2}' /proc/meminfo
}

kernel_supports_bbr() {
    [[ -f /proc/sys/net/ipv4/tcp_available_congestion_control ]] && \
        grep -q 'bbr' /proc/sys/net/ipv4/tcp_available_congestion_control
}

if [[ $EUID -ne 0 ]]; then
    echo "memguard-system-tune must be run as root" >&2
    exit 1
fi

# 1. ananicy-cpp (bundled with this package)
if systemctl enable --now ananicy-cpp.service; then
    LOG "enabled ananicy-cpp.service"
else
    WARN "failed to enable ananicy-cpp.service"
fi

# 2. zram via systemd-zram-generator
if command -v systemctl >/dev/null 2>&1; then
    ZRAM_CONF=/etc/systemd/zram-generator.conf
    if [[ -f "$ZRAM_CONF" ]]; then
        LOG "$ZRAM_CONF already exists; skipping zram setup"
    elif ! [[ -x /usr/lib/systemd/systemd-zram-generator ]] && \
         ! [[ -x /usr/lib/systemd/zram-generator ]]; then
        WARN "systemd-zram-generator not installed; skipping zram setup"
    else
        ram_kb=$(total_ram_kb)
        if [[ "$ram_kb" -lt 2097152 ]]; then
            WARN "less than 2 GiB RAM; skipping zram to avoid memory pressure"
        else
            mkdir -p /etc/systemd
            cat > "$ZRAM_CONF" <<'EOF'
[zram0]
zram-size = ram / 2
compression-algorithm = zstd
EOF
            LOG "created $ZRAM_CONF"
            systemctl daemon-reload || true
            if systemctl start systemd-zram-setup@zram0.service 2>/dev/null || \
               systemctl restart systemd-zram-setup@zram0.service 2>/dev/null; then
                LOG "started zram0"
            else
                WARN "failed to start zram0"
            fi
        fi
    fi
else
    WARN "systemctl not available; skipping zram setup"
fi

# 3. CachyOS-style vm/network sysctl tunings
SYSCTL_CONF=/etc/sysctl.d/99-memguard-system-tune.conf
if [[ -f "$SYSCTL_CONF" ]]; then
    LOG "$SYSCTL_CONF already exists; skipping sysctl tuning"
else
    {
        echo "# memguard-system-tune desktop tunings"
        echo "vm.swappiness = 100"
        echo "vm.vfs_cache_pressure = 50"
        echo "vm.dirty_ratio = 10"
        echo "vm.dirty_background_ratio = 5"
        if kernel_supports_bbr; then
            echo "net.ipv4.tcp_congestion_control = bbr"
        fi
    } > "$SYSCTL_CONF"
    LOG "created $SYSCTL_CONF"
    if sysctl -p "$SYSCTL_CONF" >/dev/null 2>&1; then
        LOG "applied sysctl settings"
    else
        WARN "failed to apply sysctl settings immediately"
    fi
fi

# 4. fstrim
if command -v fstrim >/dev/null 2>&1; then
    if fstrim -a >/dev/null 2>&1; then
        LOG "fstrim completed"
    else
        WARN "fstrim failed"
    fi
else
    WARN "fstrim not available"
fi

# 5. fstab noatime
if [[ -f /etc/fstab ]]; then
    new_fstab=/etc/fstab.memguard-new
    awk '
        /^#/ || /^$/ { print; next }
        {
            fs=$3
            opts=$4
            if ((fs=="ext4" || fs=="xfs" || fs=="btrfs") && \
                opts !~ /(^|,)atime(=|$|,)/ && \
                opts !~ /(^|,)noatime($|,)/ && \
                opts !~ /(^|,)relatime($|,)/ && \
                opts !~ /(^|,)strictatime($|,)/) {
                if (opts == "") $4 = "noatime"
                else $4 = opts ",noatime"
            }
            print
        }
    ' /etc/fstab > "$new_fstab"

    if cmp -s /etc/fstab "$new_fstab"; then
        LOG "/etc/fstab already has noatime where needed; no changes"
        rm -f "$new_fstab"
    else
        if command -v findmnt >/dev/null 2>&1; then
            if findmnt --verify "$new_fstab"; then
                backup=/etc/fstab.memguard-backup-$(date +%Y%m%d%H%M%S)
                cp /etc/fstab "$backup"
                LOG "backed up /etc/fstab to $backup"
                mv "$new_fstab" /etc/fstab
                LOG "updated /etc/fstab with noatime where needed"
            else
                WARN "fstab verification failed; not replacing /etc/fstab"
                rm -f "$new_fstab"
            fi
        else
            WARN "findmnt not available; skipping fstab update to avoid unverified changes"
            rm -f "$new_fstab"
        fi
    fi
else
    WARN "/etc/fstab not found"
fi

mkdir -p /var/lib/memguard-system-tune
touch /var/lib/memguard-system-tune/done

LOG "system tuning complete"
